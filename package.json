{
    "name": "isuccess-scan-barcode",
    "version": "1.0.0",
    "description": "iSuccess Scan Barcode — barcode scanning and order management",
    "main": "dist/main.js",
    "scripts": {
        "dev": "concurrently \"npm run dev:renderer\" \"npm run dev:main\"",
        "dev:main": "tsc -p tsconfig.main.json && electron .",
        "dev:renderer": "vite",
        "build": "npm run build:main && npm run build:renderer",
        "build:main": "tsc -p tsconfig.main.json",
        "build:renderer": "vite build",
        "dist": "electron-builder",
        "dist:win": "electron-builder --win --x64 --arm64",
        "dist:win-x64": "electron-builder --win --x64",
        "dist:win-arm64": "electron-builder --win --arm64",
        "dist:mac": "electron-builder --mac",
        "postinstall": "electron-builder install-app-deps",
        "setup": "node setup-config.js"
    },
    "keywords": [
        "barcode",
        "qc",
        "inventory",
        "electron"
    ],
    "author": "iSuccess",
    "license": "MIT",
    "devDependencies": {
        "@types/node": "^20.0.0",
        "@types/react": "^18.2.0",
        "@types/react-dom": "^18.2.0",
        "@vitejs/plugin-react": "^4.0.0",
        "concurrently": "^8.0.0",
        "electron": "^25.0.0",
        "electron-builder": "^24.0.0",
        "typescript": "^5.0.0",
        "vite": "^4.0.0"
    },
    "dependencies": {
        "axios": "^1.11.0",
        "electron-store": "^8.1.0",
        "mysql2": "^3.0.0",
        "quagga": "^0.12.1",
        "react": "^18.2.0",
        "react-dom": "^18.2.0",
        "react-pdf": "^7.0.0",
        "react-router-dom": "^6.8.0",
        "react-webcam": "^7.0.0",
        "xlsx": "^0.18.5"
    },
    "build": {
        "appId": "com.isuccess.scanbarcode",
        "productName": "iSuccess Scan Barcode",
        "directories": {
            "output": "release"
        },
        "files": [
            "dist/**/*",
            "node_modules/**/*",
            "demo-images/**/*",
            "images/**/*"
        ],
        "mac": {
            "category": "public.app-category.productivity",
            "icon": "images/logo/logo-warehouse.png"
        },
        "win": {
            "icon": "images/logo/icon.ico",
            "signAndEditExecutable": false,
            "target": [
                {
                    "target": "nsis",
                    "arch": [
                        "x64",
                        "arm64"
                    ]
                }
            ]
        },
        "linux": {
            "icon": "images/logo/logo-warehouse.png"
        },
        "nsis": {
            "oneClick": false,
            "allowToChangeInstallationDirectory": true,
            "createDesktopShortcut": true,
            "createStartMenuShortcut": true,
            "shortcutName": "iSuccess Scan Barcode",
            "uninstallDisplayName": "iSuccess Scan Barcode",
            "artifactName": "iSuccess-Scan-Barcode-Setup-${version}.${ext}",
            "deleteAppDataOnUninstall": true,
            "runAfterFinish": true,
            "include": "installer.nsh"
        }
    }
}
